{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://rentease-store.duckdns.org/api/$1"
    },
    {
      "source": "/verification_docs/(.*)",
      "destination": "https://rentease-store.duckdns.org/verification_docs/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
